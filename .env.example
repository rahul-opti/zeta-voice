# Public URL for Twilio webhooks (e.g., from ngrok)
BASE_URL="https://your-ngrok-url.ngrok-free.app"

# Twilio Credentials
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBERS=["+15551234567", "+15559876543"]
TWILIO_TTS_VOICE="alice"

# Comfort noise settings
ENABLE_COMFORT_NOISE=True

# PostgreSQL Settings (for Docker Compose)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=carriage
POSTGRES_USER=carriage
POSTGRES_PASSWORD=carriage_postgres_password

# Database Connection URL
DB_PATH=data/carriage.db

# LLM and AI Service Settings
INTENT_CLASSIFICATION_MODEL="gpt-4o-2024-08-06"
VOICEMAIL_DETECTION_MODEL="gpt-4o-2024-08-06"
TTS_PROVIDER="openai"
OPENAI_API_KEY="your_api_key"
ELEVENLABS_API_KEY="your_api_key"

# Storage Settings
LOCAL_STORAGE_DYNAMIC_CONTAINER_NAME="data/dynamic_recordings"
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;"
AZURE_STORAGE_STATIC_CONTAINER_NAME_OAI="static-recordings-oai"
AZURE_STORAGE_STATIC_CONTAINER_NAME_11LABS="static-recordings-11labs"


# Dynamics 365 Calendar Settings
DYNAMICS_ERP_BOOKING=false
DYNAMICS_API_URL="https://your-org.crm.dynamics.com"
DYNAMICS_TENANT_ID="your-azure-tenant-id"
DYNAMICS_CLIENT_ID="your-app-client-id"
DYNAMICS_CLIENT_SECRET="your-app-client-secret"

# --- Application and Security Settings ---
ENABLE_PROFILING="0"
ADMIN_API_KEY="your_admin_api_key"
USER_API_KEY="your_user_api_key"
RECORD_CALL=false
